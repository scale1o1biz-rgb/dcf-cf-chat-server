# DCF CF Chat Server — Environment Variables
# Copy this file to .env and fill in values

# ── SERVER ──────────────────────────────────────────────────────
# Port to listen on (Railway/Render set this automatically)
PORT=3000

# Environment: development | production
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (Chrome extensions always allowed)
# Example: https://degencoinflip.com,https://your-frontend.com
ALLOWED_ORIGINS=https://degencoinflip.com

# ── OPTIONAL SETTINGS ────────────────────────────────────────────
# Override default message history size (max 200)
# MAX_MSG_HISTORY=50

# Override cooldown in milliseconds
# COOLDOWN_MS=2000

# Override max message length
# MAX_MSG_LENGTH=250
